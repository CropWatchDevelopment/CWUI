{
	"name": "@cropwatchdevelopment/cwui",
	"version": "0.1.81",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/CropWatchDevelopment/CWUI.git"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"description": "CropWatch reusable Svelte 5 UI component library — CSS3-first, dark/light theming, AAA accessibility",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "svelte-kit sync && vite dev",
		"build": "vite build && npm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package --input src/lib",
		"release": "bash ./scripts/release-package.sh",
		"prepublishOnly": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"development": "./dist/index.js",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./styles": {
			"development": "./dist/styles/base.css",
			"default": "./dist/styles/base.css"
		},
		"./styles/tokens": {
			"development": "./dist/styles/tokens.css",
			"default": "./dist/styles/tokens.css"
		},
		"./styles/theme-dark": {
			"development": "./dist/styles/theme-dark.css",
			"default": "./dist/styles/theme-dark.css"
		},
		"./styles/theme-light": {
			"development": "./dist/styles/theme-light.css",
			"default": "./dist/styles/theme-light.css"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/package": "^2.3.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0"
	},
	"packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
